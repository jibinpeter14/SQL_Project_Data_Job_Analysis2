(SELECT COUNT(skills_job.skill_id) AS skill_id_count,
job_posting.job_id AS job_id_count
FROM job_postings_fact AS job_posting
INNER JOIN skills_job_dim AS skills_job
ON job_posting.job_id = skills_job.job_id
GROUP BY job_posting.job_id
ORDER BY skill_id_count DESC
LIMIT 5
)  

SELECT skills_dim.skills
FROM skills_dim
INNER JOIN (
    SELECT skill_id,
COUNT(job_id) AS skill_count
FROM skills_job_dim
GROUP BY skill_id
ORDER BY skill_count DESC
LIMIT 5
) AS top_skills 
ON skills_dim.skill_id = top_skills.skill_id
ORDER BY top_skills.skill_count DESC;





SELECT sd.skills
FROM skills_dim sd
INNER JOIN (
SELECT jpf.job_id,
sjd.skill_id 
FROM job_postings_fact jpf
INNER JOIN skills_job_dim sjd
ON jpf.job_id = sjd.job_id
ORDER BY sjd.skill_id DESC
) AS t2
ON sd.skill_id = t2.skill_id
GROUP BY sd.skills
ORDER BY COUNT(t2.skill_id) DESC
LIMIT 5;

SELECT 
company_job_count.company_id,
company_job_count.name,

CASE
WHEN job_postings_per_company < 10 THEN 'Small'
WHEN job_postings_per_company BETWEEN 10 AND 50 THEN 'Medium'
ELSE 'Large'
END AS company_size
FROM (
    SELECT COUNT(job_id) AS job_postings_per_company,
       cm.name,
       cm.company_id
       FROM job_postings_fact jpf
       INNER JOIN company_dim cm 
       ON jpf.company_id = cm.company_id
       GROUP BY cm.name, cm.company_id
) AS company_job_count;





SELECT name
FROM company_dim
INNER JOIN(SELECT company_id,
AVG(salary_year_avg)AS avg_salary
FROM job_postings_fact 
GROUP BY company_id)AS company_avg
ON company_dim.company_id = company_avg.company_id
WHERE company_avg.avg_salary > (SELECT AVG(salary_year_avg)
                                FROM job_postings_fact);



