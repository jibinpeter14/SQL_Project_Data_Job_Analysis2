WITH unique_skill_count AS(SELECT COUNT (DISTINCT sjd.skill_id)skill_id_u,
cd.company_id
FROM company_dim cd
LEFT JOIN job_postings_fact jpf
ON cd.company_id = jpf.company_id
LEFT JOIN skills_job_dim sjd
ON jpf.job_id = sjd.job_id
GROUP BY cd.company_id),

max_salary AS(SELECT jpf.company_id,
MAX(salary_year_avg) AS salary_max
FROM job_postings_fact jpf
WHERE EXISTS (
    SELECT 1
    FROM skills_job_dim sjd
    WHERE sjd.job_id = jpf.job_id
)
GROUP BY jpf.company_id)

SELECT cd.name,
unique_skill_count.skill_id_u,
max_salary.salary_max
FROM company_dim cd
LEFT JOIN unique_skill_count 
ON cd.company_id = unique_skill_count.company_id
LEFT JOIN max_salary 
ON cd.company_id = max_salary.company_id
ORDER BY
        cd.name;







