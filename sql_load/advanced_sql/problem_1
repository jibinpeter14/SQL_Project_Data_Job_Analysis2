WITH avg_salary AS(SELECT AVG(salary_year_avg) AS salary_avg,
job_country
FROM job_postings_fact
GROUP BY job_country
)
SELECT jpf.job_id,
        jpf.job_title,
        cd.name,
CASE
    WHEN jpf.salary_year_avg > avg_salary.salary_avg THEN 'Above Average'
    ELSE 'Below Average'   
END as salry_category,           
EXTRACT(MONTH FROM jpf.job_posted_date) AS month_job_posting
FROM job_postings_fact jpf
INNER JOIN company_dim as cd
ON jpf.company_id = cd.company_id
INNER JOIN avg_salary
ON jpf.job_country = avg_salary.job_country
ORDER BY month_job_posting DESC;

